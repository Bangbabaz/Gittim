{
  "name": "gittim",
  "version": "0.0.1",
  "description": "Git + tmux 风格的终端模拟器，支持分屏、分支切换与工作树管理",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "node scripts/fetch-whisper-model.mjs && electron-vite dev",
    "build": "node scripts/fetch-whisper-model.mjs && npm run typecheck && electron-vite build",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "fetch-models": "node scripts/fetch-whisper-model.mjs",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');for(const d of ['darwin-arm64','darwin-x64','linux-arm64','linux-x64']){const f=p.join('node_modules/node-pty/prebuilds',d,'spawn-helper');try{fs.chmodSync(f,0o755)}catch{}}\" && node -e \"const fs=require('fs');const f='node_modules/smart-whisper/binding.gyp';if(fs.existsSync(f)){let c=fs.readFileSync(f,'utf8');if(!c.includes('/utf-8')){c=c.replace(\\\"'VCCLCompilerTool': { 'ExceptionHandling': 1 }\\\",\\\"'VCCLCompilerTool': { 'ExceptionHandling': 1, 'AdditionalOptions': ['/utf-8'] }\\\");fs.writeFileSync(f,c);console.log('patched smart-whisper binding.gyp for UTF-8')}}\""
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "electron-updater": "^6.3.9",
    "element-plus": "^2.14.0",
    "lucide-vue-next": "^1.0.0",
    "node-pty": "^1.1.0",
    "sass": "^1.99.0",
    "shiki": "^4.1.0",
    "smart-whisper": "^0.8.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
